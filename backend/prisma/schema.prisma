generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  username     String    @unique
  email        String    @unique
  passwordHash String
  ecocoPoints  Int       @default(0)
  ecocoCoins   Int       @default(0)
  isVip        Boolean   @default(false)
  vipExpiresAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  character  Character?
  battles    Battle[]
  inventory  InventoryItem[]
  purchases  Purchase[]

  @@map("users")
}

model Character {
  id             String   @id @default(uuid())
  userId         String   @unique
  hp             Int      @default(100)
  maxHp          Int      @default(100)
  energy         Int      @default(100)
  maxEnergy      Int      @default(100)
  attackPower    Int      @default(10)
  defense        Int      @default(5)
  skinId         String   @default("default")
  battlesWon     Int      @default(0)
  monstersKilled Int      @default(0)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("characters")
}

model Monster {
  id          String        @id @default(uuid())
  name        String
  rarity      MonsterRarity @default(COMMON)
  type        MonsterType   @default(BATTERY)
  maxHp       Int
  attackPower Int
  defense     Int
  latitude    Float
  longitude   Float
  stationId   String
  sponsorName String?
  expiresAt   DateTime?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  battles Battle[]
  rewards MonsterReward[]

  @@map("monsters")
}

enum MonsterRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum MonsterType {
  BATTERY
  POLLUTION
  PLASTIC
  CORPORATE
  SEASONAL
}

model MonsterReward {
  id          String     @id @default(uuid())
  monsterId   String
  type        RewardType
  amount      Int
  itemId      String?
  couponCode  String?
  description String?

  monster Monster @relation(fields: [monsterId], references: [id], onDelete: Cascade)

  @@map("monster_rewards")
}

enum RewardType {
  ECOCO_COINS
  ECOCO_POINTS
  COUPON
  ITEM
  EQUIPMENT
}

model Battle {
  id         String       @id @default(uuid())
  userId     String
  monsterId  String
  status     BattleStatus @default(IN_PROGRESS)
  playerHp   Int
  monsterHp  Int
  turnCount  Int          @default(0)
  createdAt  DateTime     @default(now())
  finishedAt DateTime?

  user    User    @relation(fields: [userId], references: [id])
  monster Monster @relation(fields: [monsterId], references: [id])

  @@map("battles")
}

enum BattleStatus {
  IN_PROGRESS
  VICTORY
  DEFEAT
  FLED
}

model Station {
  id        String  @id @default(uuid())
  name      String
  address   String?
  latitude  Float
  longitude Float
  type      String  @default("battery")
  isActive  Boolean @default(true)

  @@map("stations")
}

model InventoryItem {
  id        String   @id @default(uuid())
  userId    String
  itemId    String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("inventory_items")
}

model ShopItem {
  id          String   @id @default(uuid())
  name        String
  description String
  type        String
  coinPrice   Int
  ntdPrice    Int?
  imageUrl    String?
  stats       Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  purchases Purchase[]

  @@map("shop_items")
}

model Purchase {
  id         String   @id @default(uuid())
  userId     String
  itemId     String
  coinsPaid  Int?
  ntdPaid    Int?
  createdAt  DateTime @default(now())

  user User     @relation(fields: [userId], references: [id])
  item ShopItem @relation(fields: [itemId], references: [id])

  @@map("purchases")
}

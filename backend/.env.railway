# 這些變數在 Railway dashboard 上設定
# 不要 commit 真實值

PORT=3000
NODE_ENV=production

# Railway 內建 PostgreSQL plugin 會自動注入 DATABASE_URL
# DATABASE_URL=postgresql://...

# Upstash Redis (https://upstash.com 免費帳號)
# REDIS_URL=rediss://...

# 自己產一個隨機字串
# openssl rand -base64 32
JWT_SECRET=CHANGE_ME_IN_RAILWAY_DASHBOARD
